# Relayer environment variables
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
MOBILE_MONEY_PROVIDER_ADDRESS=0xYourMobileMoneyProviderContractAddress
WASDI_ORACLE_CONNECTOR_ADDRESS=0xYourWASDIOracleConnectorContractAddress
BENEFICIARY_REGISTRY_PATH=./relayer/beneficiaries.json
SIMULATE_PAYMENTS=true

# Orange Money configuration
ORANGE_MONEY_API_URL=https://sandbox-api.orange.com/payment
ORANGE_MONEY_API_KEY=your-orange-money-api-key
ORANGE_MONEY_MERCHANT_ID=your-merchant-id
ORANGE_MONEY_CALLBACK_URL=https://your-relayer-url/webhooks/orange-money

# Wave configuration
WAVE_API_URL=https://sandbox-api.wave.com/payment
WAVE_API_KEY=your-wave-api-key

# Free Money configuration
FREE_MONEY_API_URL=https://sandbox-api.freemoney.com/payment
FREE_MONEY_API_KEY=your-freemoney-api-key

# E-Money configuration
EMONEY_API_URL=https://sandbox-api.emoney.com/payment
EMONEY_API_KEY=your-emoney-api-key

# Monitoring (optional)
NEWRELIC_LICENSE_KEY=
DATADOG_API_KEY=
SENTRY_DSN=
